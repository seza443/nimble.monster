DATABASE_URL="file:db/dev.db"

AUTH_SECRET="run 'pnpx auth secret' to generate"

# or /opt/homebrew/bin/chromium etc
PUPPETEER_EXECUTABLE_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"

# Discord OAuth
AUTH_DISCORD_ID=
AUTH_DISCORD_SECRET=

# Optional: extra allowed origins for server action CSRF (comma-separated)
# ALLOWED_ORIGINS=tail26991.ts.net

# Optional: Feature flags
# NEXT_PUBLIC_FEATURE_CLASS_AUTOSAVE=true

# Optional: OpenTelemetry
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_SERVICE_NAME=nimble-nexus
